// Copy this file to AISecrets.xcconfig. AI endpoint/model can now be served by the secure backend;
// fill them only as local fallbacks. Escape slashes in URLs to avoid // being parsed as comments.
AI_API_ENDPOINT = 
AI_API_KEY = 
AI_MODEL = 

// Notion OAuth (client_id is safe to embed in app)
NOTION_CLIENT_ID = 302d872b-594c-8040-8f0c-xxxxxxxxxx
NOTION_REDIRECT_URI = https:\/\/isla-reader.top\/notion\/callback

// Secure server config for fetching AI API keys over HTTPS + HMAC
SECURE_SERVER_BASE_URL = https:\/\/isla-reader.top:443
SECURE_SERVER_CLIENT_ID = ios-LanRead
SECURE_SERVER_CLIENT_SECRET = replace-with-strong-secret
SECURE_SERVER_REQUIRE_TLS = true
// Keep identical to ISLA_METRICS_INGEST_TOKEN on the server; leave empty only if the server reuses SECURE_SERVER_CLIENT_SECRET
SECURE_SERVER_METRICS_TOKEN = replace-with-metrics-ingest-token

// AdMob production ad unit IDs (must not use Google test IDs in release)
ADMOB_BANNER_AD_UNIT_ID = your-banner-ad-unit-id
ADMOB_REWARDED_INTERSTITIAL_AD_UNIT_ID = your-rewarded-interstitial-ad-unit-id
ADMOB_INTERSTITIAL_AD_UNIT_ID = your-interstitial-ad-unit-id

// Optional ad-free build variant. Leave empty for normal ad-enabled builds.
// Example: -DLANREAD_ADS_DISABLED
ADS_SWIFT_FLAGS =
OTHER_SWIFT_FLAGS = $(inherited) $(ADS_SWIFT_FLAGS)
